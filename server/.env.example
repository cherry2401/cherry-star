# Server Config
PORT=3001
NODE_ENV=development

# JWT — Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_RANDOM_64_BYTES_HEX

# BaoStar API
BAOSTAR_API_DOMAIN=https://dichvu.baostar.net
BAOSTAR_API_KEY=your-baostar-api-key-here

# Database
DB_PATH=./database/autolike.db

# Admin defaults (only used for initial seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
